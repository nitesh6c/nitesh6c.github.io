# Copy to .env.local for local development (not committed).
VITE_APP_ENV=development

# Application ID from https://www.worldcubeassociation.org/oauth/applications
VITE_WCA_CLIENT_ID=

VITE_BASE_URL=/

# Optional: WCA staging environment
# VITE_WCA_ORIGIN=https://staging-api.worldcubeassociation.org
# VITE_WCA_OAUTH_ORIGIN=https://staging.worldcubeassociation.org

# Analytics (optional)
VITE_GA_MEASUREMENT_ID=
VITE_UMAMI_SRC=
VITE_UMAMI_WEBSITE_ID=

# NotifyComp (optional; requires Netlify functions for remote auth)
VITE_NOTIFY_COMP_ORIGIN=
VITE_NOTIFYCOMP_API_ORIGIN=
VITE_NOTIFYCOMP_WS_ORIGIN=

# Feature flags
VITE_FEATURE_PERSONAL_USER_PAGE=
